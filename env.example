# This is only a .env example
# Do not commit your real token.
# Usage: cp env.example .env, then edit .env

# Preferred token name (used by fetch.js). Keep this secret.
GITHUB_TOKEN="YOUR GITHUB TOKEN HERE"

# GitHub username to fetch pinned repos/profile info for.
GITHUB_USERNAME="YOUR GITHUB USERNAME HERE"

# Set to "true" to fetch profile data from GitHub during start/build.
USE_GITHUB_DATA="true"

# Set to your username in order to fetch blog data from Medium (if enabled in portfolio.js)
MEDIUM_USERNAME="YOUR MEDIUM USERNAME HERE"
